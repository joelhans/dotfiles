# Common shortcuts
alias reload='source ~/.zshrc'
alias _='sudo -E'
alias dnf='sudo dnf'
alias rr='rm -rf'
alias zshrc="$EDITOR $HOME/.zshrc && reload"
alias aliases="$EDITOR $HOME/.zsh_aliases && reload"

alias k=kubectl

# Directory traversal
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'
alias -- -='cd -'

alias dot='cd ~/dotfiles'
alias dl='cd ~/Downloads'

# Directory listing
if ls --color > /dev/null 2>&1; then # GNU `ls`
  colorflag="--color"
else # macOS `ls`
  colorflag="-G"
  export LSCOLORS='BxBxhxDxfxhxhxhxhxcxcx'
fi
alias l="ls -lF ${colorflag}"
alias la="ls -laF ${colorflag}"
alias lsd="ls -lF ${colorflag} | grep --color=never '^d'"
alias ls="command ls ${colorflag}"

# IP addresses
alias pubip="dig +short myip.opendns.com @resolver1.opendns.com"
alias locip="ifconfig -a | grep -o 'inet6\? \(addr:\)\?\s\?\(\(\([0-9]\+\.\)\{3\}[0-9]\+\)\|[a-fA-F0-9:]\+\)' | awk '{ sub(/inet6? (addr:)? ?/, \"\"); print }'"

# Git
alias gcm='git checkout main'
alias gst='git status'
alias gs='git switch'
alias gsm='git switch main'
alias gsync='git pull upstream main && git push origin main'
alias gpo='git push -u origin HEAD'
alias gnew='git checkout -b'
alias gca='git commit -a'
alias ga='git add'
alias 'gca!'='git commit -a --amend'
alias glr='git pull --rebase'
alias gam='git add . && git commit -m'
function gampo { git add . && git commit -m "$1" && git push -u origin HEAD }

# Zellij (zl and zc are functions in .zshrc)
alias zj='zellij'
alias za='zellij attach'
alias zk='zellij kill-session'
alias zkall='zellij kill-all-sessions'

# GitHub CLI
alias ghghost="gh api /notifications -X GET | jq -r '.[].id' | xargs -I {} gh api /notifications/threads/{} -X PATCH"

# Python
alias python=python3
alias pip=pip3

# YOLO mode
alias yolo='claude --dangerously-skip-permissions'
