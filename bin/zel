#!/usr/bin/env zsh
# zel — fuzzy-jump to any repo worktree in a named Zellij session
#
# Config: $XDG_CONFIG_HOME/zel/roots (default: ~/.config/zel/roots)
# One root directory per line; lines starting with # are ignored.

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zel"
ROOTS_FILE="$CONFIG_DIR/roots"

die() { print -u2 -- "zel: $*"; exit 1 }
need() { command -v "$1" &>/dev/null || die "required tool not found: $1" }

need fzf
need git
need zellij

[[ -f "$ROOTS_FILE" ]] || die "no roots config found at $ROOTS_FILE
Create it with one root directory per line, e.g.:
  ~/code
  ~/work"

# ---------------------------------------------------------------------------
# Discovery: scan roots for git repos and their worktrees
# Output format: repo_name TAB branch TAB abs_path
# ---------------------------------------------------------------------------

gather() {
  local root repo_dir repo_name wt_path wt_branch wt_bare

  while IFS= read -r root || [[ -n "$root" ]]; do
    [[ -z "$root" || "$root" == \#* ]] && continue
    root="${root/#\~/$HOME}"
    [[ -d "$root" ]] || continue

    while IFS= read -r repo_dir; do
      repo_name=$(basename "$repo_dir")
      wt_path='' wt_branch='' wt_bare=0

      # Extra echo flushes the final block from porcelain output
      while IFS= read -r line; do
        case "$line" in
          'worktree '*)  wt_path="${line#worktree }" ;;
          'branch '*)    wt_branch="${line#branch refs/heads/}" ;;
          bare)          wt_bare=1 ;;
          '')
            if [[ -n "$wt_path" && $wt_bare -eq 0 ]]; then
              printf '%s\t%s\t%s\n' \
                "$repo_name" \
                "${wt_branch:-$(basename "$wt_path")}" \
                "$wt_path"
            fi
            wt_path='' wt_branch='' wt_bare=0
            ;;
        esac
      done < <({ git -C "$repo_dir" worktree list --porcelain 2>/dev/null; echo; })

    done < <(
      find "$root" -maxdepth 2 -name '.git' \( -type d -o -type f \) -print 2>/dev/null \
        | sed 's|/\.git$||' | sort -u
    )
  done < "$ROOTS_FILE"
}

entries=$(gather)
[[ -z "$entries" ]] && die "no repos found under configured roots"

# ---------------------------------------------------------------------------
# Pick: fzf with tab-delimited fields; {3} in preview refers to the path
# ---------------------------------------------------------------------------

IFS=$'\t' read -r repo tab wt_path < <(
  printf '%s\n' "$entries" \
    | fzf \
        --delimiter $'\t' \
        --with-nth 1,2 \
        --tabstop 28 \
        --prompt '  ' \
        --height 40% \
        --layout reverse \
        --border rounded \
        --preview 'git -C {3} log --oneline --color=always -15 2>/dev/null' \
        --preview-window 'right:45%:wrap' \
    || true
)

[[ -z "$repo" ]] && exit 0

# ---------------------------------------------------------------------------
# Zellij helpers
# ---------------------------------------------------------------------------

_active_sessions() {
  zellij list-sessions --no-formatting 2>/dev/null \
    | awk '$0 !~ /EXITED/ {print $1}'
}

session_exists() { _active_sessions | grep -qx "$1" }

_wait_for_session() {
  local sess=$1 i
  for i in {1..20}; do
    session_exists "$sess" && return 0
    sleep 0.1
  done
  return 1
}

ensure_tab() {
  local sess=$1 name=$2 cwd=$3
  # go-to-tab-name exits non-zero if the tab doesn't exist
  zellij --session "$sess" action go-to-tab-name "$name" 2>/dev/null \
    || zellij --session "$sess" action new-tab --name "$name" --cwd "$cwd"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if session_exists "$repo"; then
  ensure_tab "$repo" "$tab" "$wt_path"
else
  # --create-background (-b): creates the session detached without needing
  # terminal control, so this works correctly from inside or outside Zellij.
  # The default layout (~/.config/zellij/layouts/default.kdl) is used.
  zellij attach -b "$repo"
  _wait_for_session "$repo" || die "timed out waiting for session '$repo'"
  zellij --session "$repo" action rename-tab "$tab"
  zellij --session "$repo" action write-chars "cd $(printf '%q' "$wt_path") && clear"$'\n'
fi

# exec zellij attach replaces the current process with a Zellij client.
# From outside Zellij this attaches normally; from inside, Zellij 0.38+
# switches the terminal to the target session rather than nesting.
exec zellij attach "$repo"
